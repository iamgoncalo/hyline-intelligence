# ── HYLINE Intelligence · environment variables ──
# Copy to .env (do NOT commit .env)

# Gemini 2.0 Flash for the Assistente agent (optional — falls back to rules)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Daily call cap for the Assistente (default 100)
ASSISTANT_DAILY_CAP=100

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database (relative to repo root)
DB_PATH=data/hyline.db

# Refresh intervals (seconds) — must match config.yaml
DASHBOARD_REFRESH=1
MONITOR_TICK=1
